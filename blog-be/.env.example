# Server
NODE_ENV=development
PORT=4000
API_PREFIX=api

# CORS — comma-separated origins (FE dev: http://localhost:3000)
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# PostgreSQL — docker compose (postgres dùng network_mode: host → localhost:5432)
DATABASE_URL=postgresql://blog:blog@127.0.0.1:5432/blog

# Redis (docker-compose map 6380→6379 trong container)
REDIS_URL=redis://localhost:6380

# JWT (đổi production)
JWT_SECRET=dev-change-me-min-32-chars-long-secret!!
JWT_EXPIRES=7d

# Seed (optional)
# SEED_ADMIN_EMAIL=admin@local.dev
# SEED_ADMIN_PASSWORD=admin123

# MinIO local (docker compose) — upload ảnh
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=blog-uploads
S3_REGION=us-east-1
# URL trình duyệt tải ảnh (path-style)
S3_PUBLIC_BASE=http://localhost:9000/blog-uploads
